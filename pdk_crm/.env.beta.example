# Phase 10.Beta — copy on VPS to pdk_crm/.env.docker (chmod 600). Do not commit.
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Generate DB password: openssl rand -base64 24

DJANGO_ENV=docker
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_STRING
DEBUG=False

ALLOWED_HOSTS=pdk.godelta.us

USE_SQLITE=false
DB_NAME=tax_operations
DB_USER=pdkcrm
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_HOST=crm_db
DB_PORT=5432

# Beta defaults — enable QBO later per docs/BILLING.md
FEATURE_QBO=false
BILLING_PROVIDER=fake
FEATURE_AUTO_SEND_INVOICES=false
FEATURE_PARSER_PATH_A=true

# Compose also sets PDF_MANAGER_BASE_URL=http://pdf_web:8000 on crm_web
PDF_MANAGER_BASE_URL=http://pdf_web:8000

# Cloudflare Tunnel terminates TLS; cloudflared sends X-Forwarded-Proto: https
SECURE_PROXY_SSL_PROTO=https

ANALYTICS_ENABLED=true
